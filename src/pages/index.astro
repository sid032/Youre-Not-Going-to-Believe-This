---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<div class="header">
<h1>Life Stories of Drew</h1>
<p class="subtitle">Interactive Knowledge Graph • 22 Autobiographical Narratives</p>
</div>

<div class="controls">
<a href="/knowledge-graph.html" class="sync-btn">View Knowledge Graph</a>
<button onclick="syncFromGDoc()">Sync from Google Doc</button>
<input type="text" id="searchInput" placeholder="Search stories..." oninput="searchStories()">
</div>

<div class="themes-grid" id="themesGrid"></div>

<div class="modal" id="storyModal">
<div class="modal-content">
<span class="close" onclick="closeModal()">&times;</span>
<div id="modalBody"></div>
</div>
</div>
</Layout>

<style>
body{background:linear-gradient(135deg,#0c0c14 0%,#1a1a2e 100%);color:#e0e0ff;font-family:system-ui;min-height:100vh;margin:0}
.header{text-align:center;padding:40px 20px 20px}
.header h1{color:#ffd43b;margin:0;font-size:2.5em}
.subtitle{color:#888;margin:10px 0 0}
.controls{display:flex;justify-content:center;gap:20px;margin-bottom:30px;flex-wrap:wrap;padding:0 20px}
.controls button{background:#51cf66;border:none;padding:12px 24px;border-radius:8px;cursor:pointer;font-weight:bold}
.controls input{padding:12px 16px;border-radius:8px;border:1px solid #444;background:rgba(255,255,255,0.1);color:white;width:250px}
.themes-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;padding:20px}
.theme-card{background:rgba(22,33,62,0.6);border-radius:15px;padding:20px;min-width:280px;border:2px solid}
.theme-card.trauma{border-color:#ff6b6b}
.theme-card.music{border-color:#4dabf7}
.theme-card.travel{border-color:#51cf66}
.theme-card.paranormal{border-color:#cc5500}
.theme-card.spiritual{border-color:#ffd43b}
.theme-card.family{border-color:#da77f2}
.theme-card h3{margin:0 0 15px 0;border-bottom:1px solid #444;padding-bottom:10px}
.theme-card.trauma h3{color:#ff6b6b}
.theme-card.music h3{color:#4dabf7}
.theme-card.travel h3{color:#51cf66}
.theme-card.paranormal h3{color:#cc5500}
.theme-card.spiritual h3{color:#ffd43b}
.theme-card.family h3{color:#da77f2}
.theme-card ul{list-style:none;padding:0;margin:0}
.theme-card li{padding:8px 12px;margin:5px 0;background:rgba(0,0,0,0.3);border-radius:8px;font-size:14px;cursor:pointer;border-left:4px solid}
.theme-card.trauma li{border-color:#ff6b6b}
.theme-card.music li{border-color:#4dabf7}
.theme-card.travel li{border-color:#51cf66}
.theme-card.paranormal li{border-color:#cc5500}
.theme-card.spiritual li{border-color:#ffd43b}
.theme-card.family li{border-color:#da77f2}
.modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:100}
.modal-content{background:#16213e;margin:5% auto;padding:30px;border-radius:15px;max-width:700px;position:relative}
.close{position:absolute;right:20px;top:15px;font-size:28px;cursor:pointer;color:white}
.story-link{color:#51cf66;text-decoration:none;font-size:12px;margin-top:10px;display:inline-block}
</style>

<script>
async function loadGraph(){const data=await(await fetch('/data/stories.json')).json();renderThemes(data.themes,data.stories);}
function renderThemes(themes,stories){document.getElementById('themesGrid').innerHTML=themes.map(t=>`<div class="theme-card ${t.id}"><h3>${t.emoji} ${t.label}</h3><ul>${t.stories.map(s=>`<li onclick="showStory('${s}')">${stories[s].title}</li>`).join('')}</ul></div>`).join('');}
async function showStory(id){const data=await(await fetch('/data/stories.json')).json();const s=data.stories[id];document.getElementById('modalBody').innerHTML=`<h2>${s.title}</h2><p>${s.preview}</p><p><strong>Location:</strong> ${s.chapterRange||s.googleDocHeading}</p><a href="${data.googleDoc.url}" target="_blank" class="story-link">Open in Google Doc →</a>`;document.getElementById('storyModal').style.display='block';}
function closeModal(){document.getElementById('storyModal').style.display='none';}
function searchStories(){}
function syncFromGDoc(){alert('Run: gws drive files export --params \'{\"fileId\":\"11nLn1Z10m0Rts7r6mbzfp-2CQVbrlCbG\"}\'');}
loadGraph();
</script>
